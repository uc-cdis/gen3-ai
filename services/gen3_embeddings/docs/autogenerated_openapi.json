      "post": {
        "tags": [
          "Embeddings"
        ],
        "summary": "Create embeddings in collection",
        "description": "TODO: implementaion for StringArrayInput and ai_model\nTODO: auth related\nTODO: work for authz_version\n\nCreate one or more embeddings in a specific collection.\n\nThis minimal implementation only accepts raw numeric vectors.\n\nArgs:\n    request: The request object\n    collection_name: Name of the collection.\n    body: Request body containing a list of embedding vectors.\n    ai_model: Optional model name; not used in this minimal version.\n    no_embeddings_info: If True, omit the 'info' block in each embedding result.\n    dal: Data access layer dependency.\n\nReturns:\n    EmbeddingResponseNoCollection containing the created embeddings.\n\nRaises:\n    HTTPException: 404 if collection is not found; 400 if dimensions mismatch.",
        "operationId": "create_embeddings_in_collection_vectorstore_collections__collection_name__embeddings_post",
        "parameters": [
          {
            "name": "collection_name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Collection Name"
            }
          },
          {
            "name": "ai_model",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Ai Model"
            }
          },
          {
            "name": "no_embeddings_info",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "No Embeddings Info"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEmbeddingsBody"
              }
            }
          }
        },
